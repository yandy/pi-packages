{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 1,
		"lineWidth": 120,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all",
			"semicolons": "always",
			"arrowParentheses": "always"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"style": { "noUnusedTemplateLiteral": "off" },
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noEmptyBlockStatements": "off"
			}
		}
	},
	"files": { "includes": ["**/*.ts", "**/*.json"], "ignoreUnknown": true }
}
