{
	"name": "@yandy0725/pi-coding-tools",
	"publishConfig": {
		"access": "public"
	},
	"version": "0.5.3",
	"description": "pi package enabling ls/find/grep built-in tools",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/yandy/pi-packages",
		"directory": "pi-coding-tools"
	},
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"files": [
		"index.ts",
		"src/"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write ."
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.80.2",
		"@earendil-works/pi-ai": ">=0.80.2"
	},
	"dependencies": {
		"@ast-grep/cli": "^0.44.0",
		"vscode-jsonrpc": "^8.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/node": "^26.1.1",
		"typescript": "~6.0.3",
		"vitest": "^3.0.0"
	}
}
