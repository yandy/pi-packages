{
	"name": "@yandy0725/pi-permission-system",
	"publishConfig": {
		"access": "public"
	},
	"version": "0.1.0",
	"description": "Permission enforcement extension for the Pi coding agent",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/yandy/pi-packages",
		"directory": "pi-permission-system"
	},
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"files": [
		"index.ts",
		"src/",
		"config/",
		"schemas/"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check ."
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.74.0",
		"@earendil-works/pi-tui": ">=0.74.0"
	},
	"dependencies": {
		"tree-sitter-bash": "^0.25.1",
		"web-tree-sitter": "^0.26.9"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/node": "^22.0.0",
		"typescript": "~5.7.0",
		"vitest": "^3.0.0"
	}
}
