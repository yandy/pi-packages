{
	"name": "@yandy0725/pi-container-sandbox",
	"publishConfig": {
		"access": "public"
	},
	"version": "0.10.0",
	"description": "pi coding-agent extension that runs every read/write/edit/bash op inside a per-session Docker container",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/yandy/pi-packages",
		"directory": "pi-container-sandbox"
	},
	"type": "module",
	"files": [
		"index.ts",
		"src/",
		"docker/"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"build-image": "node --experimental-strip-types scripts/build-image.ts",
		"clean": "rm -rf dist"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.80.2"
	},
	"devDependencies": {
		"@types/dockerode": "^4.0.1"
	},
	"dependencies": {
		"dockerode": "^5.0.0"
	}
}
