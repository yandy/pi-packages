{
	"name": "@yandy0725/pi-ask-user",
	"publishConfig": {
		"access": "public"
	},
	"version": "0.2.0",
	"description": "Interactive ask_user tool for pi-coding-agent with searchable split-pane selection UI, multi-select, and freeform input",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/yandy/pi-packages",
		"directory": "pi-ask-user"
	},
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"files": [
		"index.ts",
		"src/",
		"skills/"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write ."
	},
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.80.2",
		"@earendil-works/pi-tui": ">=0.80.2",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/node": "^22.0.0",
		"typescript": "~6.0.3",
		"vitest": "^3.0.0"
	}
}
